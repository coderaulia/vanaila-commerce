# Public site base URL used for canonical links and sitemap entries.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public URL used to rewrite `/media/...` and `/portfolio/...` asset paths to a CDN or Supabase bucket.
# If empty, uploaded local assets use NEXT_PUBLIC_SITE_URL.
MEDIA_PUBLIC_BASE_URL=
NEXT_PUBLIC_MEDIA_BASE_URL=

# Initial admin user bootstrap for database-backed auth.
# The first login will create this admin user if admin_users is empty.
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=change-this-password
CMS_ADMIN_NAME=Administrator

# Legacy fallback used only for compatibility and one-time bootstrap if no password is set.
CMS_ADMIN_TOKEN=

# Supabase Postgres runtime URL used by the app.
DATABASE_URL=

# Optional direct migration URL if you want to keep runtime and migration credentials separate.
DATABASE_URL_MIGRATION=

# Optional Postgres pool cap for constrained hosting plans.
# The app now defaults to a conservative pool during `next build`, but you can force a lower value if needed.
CMS_DB_POOL_MAX=

# Optional fixture preset for `npm run db:seed:file` when you want deterministic sample data.
CMS_SEED_FIXTURE=

# Optional Supabase Storage configuration for media uploads.
# When set, admin media uploads are stored in Supabase instead of the local public/ folder.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cms-media

# Optional fallback organization values for structured data.
CMS_ORG_NAME=Acme Marketing
CMS_ORG_LOGO=https://placehold.co/240x80/png

# Optional webhook URL to receive contact form submissions.
CONTACT_NOTIFICATION_WEBHOOK_URL=
CONTACT_NOTIFICATION_WEBHOOK_METHOD=POST
CONTACT_NOTIFICATION_WEBHOOK_TOKEN=

# Number of trusted reverse proxies in front of this app.
# Set to 0 for direct connections (no proxy). Set to 1 if behind Vercel, Cloudflare, or a single nginx.
# This determines how X-Forwarded-For is parsed for rate limiting — wrong values allow IP spoofing.
TRUSTED_PROXY_COUNT=0

# Optional server-side pepper for password hashing (M-2 hardening).
# When set, all password hashes are XOR'd with this value before storage.
# A DB dump alone is insufficient to crack passwords if this secret is not also leaked.
# Generate a value with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this after users have been created requires a password reset migration.
PASSWORD_PEPPER=

# ─── Store Module ────────────────────────────────────────────────────────────
# Set to "true" to enable the e-commerce store module (products, orders, customers).
ENABLE_STORE_MODULE=false

# Secret for signing public order receipt links.
# Generate a value with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORDER_RECEIPT_SECRET=

# Midtrans payment gateway credentials.
# Get these from https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Set to "true" for production Midtrans environment.
MIDTRANS_PRODUCTION=false

# Resend email service for order notifications.
# Get API key from https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@yourdomain.com
