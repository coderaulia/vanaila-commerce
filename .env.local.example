# ─── Local Development (Docker Postgres) ─────────────────────────────────────
# Copy this file to .env.local and adjust as needed.
# Start the local database with: docker compose up -d
# Then run: npm run db:migrate && npm run db:seed:file

NEXT_PUBLIC_SITE_URL=http://localhost:3000

CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=localdev123
CMS_ADMIN_NAME=Admin

# Local Docker Postgres — both runtime and migration use the same direct URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vanaila_dev
DATABASE_URL_MIGRATION=postgresql://postgres:postgres@localhost:5432/vanaila_dev

CMS_ORG_NAME=Vanaila Digital
CMS_ORG_LOGO=

# Store module (NEXT_PUBLIC_ required so AdminNav client component can read it)
NEXT_PUBLIC_ENABLE_STORE_MODULE=true
ENABLE_STORE_MODULE=true
ORDER_RECEIPT_SECRET=local-receipt-secret-change-me

# Leave these empty for local dev — media uploads fall back to local disk (public/)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Midtrans sandbox (optional for local payment testing)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_PRODUCTION=false

# Resend (optional for local email testing)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@localhost
